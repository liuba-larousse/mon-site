---
import { siteConfig } from "../site.config";

const {
  title = "Prêt à rendre votre LinkedIn cohérent avec votre expertise ?",
  subtitle = "On clarifie votre positionnement, puis on construit une présence régulière qui attire les bonnes conversations.",
  callLabel = "Réserver un appel",
  whatsappLabel = "Envoyer un message WhatsApp",
} = Astro.props;
---

<section class="rounded-3xl bg-brand-navy px-6 py-10 text-white md:px-10 md:py-12">
  <div class="grid gap-6 md:grid-cols-[1.6fr_1fr] md:items-center">
    <div>
      <h2 class="text-2xl font-semibold tracking-tight md:text-3xl">{title}</h2>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/75 md:text-base">
        {subtitle}
      </p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row md:flex-col">
      <a
        href={siteConfig.cta.callUrl}
        class="inline-flex items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-semibold text-brand-navy hover:bg-white/90"
      >
        {callLabel}
      </a>
      <a
        href={siteConfig.cta.whatsappUrl}
        class="inline-flex items-center justify-center rounded-full border border-white/25 px-5 py-3 text-sm font-semibold text-white hover:bg-white/10"
      >
        {whatsappLabel}
      </a>
    </div>
  </div>
</section>

