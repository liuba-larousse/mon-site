---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import { siteConfig } from "../site.config";
---

<BaseLayout title={`À propos | ${siteConfig.brand}`} description="Une approche positionnement-first : clarté, cohérence, crédibilité.">
  <header class="max-w-3xl">
    <h1 class="text-4xl font-semibold tracking-tight text-slate-950 md:text-5xl">À propos</h1>
    <p class="mt-4 text-base leading-relaxed text-slate-600 md:text-lg">
      Votre audience n’a pas besoin de plus de posts. Elle a besoin de comprendre votre valeur — vite et clairement.
    </p>
  </header>

  <section class="mt-10 grid gap-6 md:grid-cols-2 md:items-start">
    <div class="rounded-3xl border border-slate-200 bg-white p-7 md:p-8">
      <h2 class="text-xl font-semibold text-slate-950">Positionnement & voix</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-600 md:text-base">
        On part de vos idées, de vos expériences et de votre jugement. L’objectif : une présence LinkedIn qui sonne juste,
        pas “parfaite”.
      </p>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-7 md:p-8">
      <h2 class="text-xl font-semibold text-slate-950">Clarté & régularité</h2>
      <p class="mt-3 text-sm leading-relaxed text-slate-600 md:text-base">
        La visibilité compense rarement un message flou. On privilégie une promesse nette et une exécution régulière.
      </p>
    </div>
  </section>

  <section class="mt-16">
    <CTA />
  </section>
</BaseLayout>

