---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | Conseils LinkedIn (FR)" description="Articles sur le ghostwriting LinkedIn, le positionnement et la stratégie de contenu.">
  <header class="max-w-3xl">
    <h1 class="text-4xl font-semibold tracking-tight text-slate-950 md:text-5xl">Blog</h1>
    <p class="mt-4 text-base leading-relaxed text-slate-600 md:text-lg">
      Des idées concrètes (en français) pour clarifier votre message et publier sans vous épuiser.
    </p>
  </header>

  <section class="mt-10 grid gap-4 md:grid-cols-2">
    {posts.map((post) => (
      <a
        href={`/blog/${post.slug}/`}
        class="group rounded-3xl border border-slate-200 bg-white p-7 transition hover:border-slate-300"
      >
        <div class="text-xs font-semibold uppercase tracking-wide text-slate-500">
          {post.data.pubDate.toLocaleDateString("fr-FR", { year: "numeric", month: "long", day: "numeric" })}
        </div>
        <h2 class="mt-2 text-xl font-semibold tracking-tight text-slate-950 group-hover:underline">
          {post.data.title}
        </h2>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">{post.data.description}</p>
        {post.data.tags?.length ? (
          <div class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((t) => (
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">{t}</span>
            ))}
          </div>
        ) : null}
      </a>
    ))}
  </section>
</BaseLayout>

