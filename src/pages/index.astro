---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import { siteConfig } from "../site.config";
---

<BaseLayout>
  <section class="grid gap-10 md:grid-cols-2 md:items-center">
    <div>
      <p class="inline-flex items-center rounded-full border border-brand-navy/15 bg-white/50 px-3 py-1 text-xs font-semibold text-brand-navy/80">
        Ghostwriting LinkedIn • Positionnement • Visibilité
      </p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-brand-navy md:text-5xl">
        Faites correspondre votre LinkedIn à votre expertise.
      </h1>
      <p class="mt-4 max-w-xl text-base leading-relaxed text-brand-navy/70 md:text-lg">
        Un système de contenu en français qui clarifie votre offre, renforce votre crédibilité et transforme la visibilité en conversations qualifiées — sans y passer vos semaines.
      </p>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a
          href={siteConfig.cta.callUrl}
          class="inline-flex items-center justify-center rounded-full bg-brand-blue px-5 py-3 text-sm font-semibold text-white hover:bg-brand-navy"
        >
          Réserver un appel stratégique
        </a>
        <a
          href={siteConfig.cta.whatsappUrl}
          class="inline-flex items-center justify-center rounded-full border border-brand-navy/15 bg-white/40 px-5 py-3 text-sm font-semibold text-brand-navy hover:bg-white/60"
        >
          Écrire sur WhatsApp
        </a>
      </div>

      <dl class="mt-10 grid grid-cols-2 gap-4 rounded-3xl border border-brand-navy/10 bg-white/50 p-6">
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-brand-navy/60">Impressions</dt>
          <dd class="mt-1 text-2xl font-semibold text-brand-navy">2–5×</dd>
          <p class="mt-1 text-sm text-brand-navy/70">en 60–90 jours</p>
        </div>
        <div>
          <dt class="text-xs font-semibold uppercase tracking-wide text-brand-navy/60">Vues de profil</dt>
          <dd class="mt-1 text-2xl font-semibold text-brand-navy">+30–70%</dd>
          <p class="mt-1 text-sm text-brand-navy/70">avec un profil clair</p>
        </div>
      </dl>
    </div>

    <div class="rounded-3xl border border-brand-navy/10 bg-gradient-to-b from-white/60 to-white/20 p-8">
      <div class="rounded-2xl bg-white/60 p-6 shadow-sm ring-1 ring-brand-navy/10">
        <p class="text-xs font-semibold text-brand-navy/60">Exemple de structure hebdomadaire</p>
        <ul class="mt-4 space-y-3 text-sm text-brand-navy/80">
          <li class="rounded-xl border border-brand-navy/10 bg-white/60 px-4 py-3">
            <span class="font-semibold text-brand-navy">Post 1</span> — opinion + insight (positionnement)
          </li>
          <li class="rounded-xl border border-brand-navy/10 bg-white/60 px-4 py-3">
            <span class="font-semibold text-brand-navy">Post 2</span> — cas client / preuve (crédibilité)
          </li>
          <li class="rounded-xl border border-brand-navy/10 bg-white/60 px-4 py-3">
            <span class="font-semibold text-brand-navy">Post 3</span> — méthode / framework (valeur)
          </li>
        </ul>
        <p class="mt-5 text-sm text-brand-navy/70">
          Tout est écrit dans votre voix, validé par vous, et aligné sur votre objectif (leads, partenariats, recrutement…).
        </p>
      </div>
    </div>
  </section>

  <section class="mt-16">
    <h2 class="text-2xl font-semibold tracking-tight text-brand-navy">Pour qui ?</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
      {[
        {
          title: "Dirigeants B2B",
          text: "Vous voulez que votre expertise soit comprise en 10 secondes et que LinkedIn devienne un canal d’opportunités.",
        },
        {
          title: "Consultants & coaches",
          text: "Vous vendez de la transformation, pas des heures. Vous avez besoin d’une visibilité crédible et régulière.",
        },
        {
          title: "Indépendants premium",
          text: "Vous voulez attirer des clients alignés sans tomber dans les “tactiques” ou les posts génériques.",
        },
      ].map((c) => (
        <div class="rounded-3xl border border-brand-navy/10 bg-white/50 p-6">
          <div class="text-base font-semibold text-brand-navy">{c.title}</div>
          <p class="mt-2 text-sm leading-relaxed text-brand-navy/70">{c.text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mt-16">
    <h2 class="text-2xl font-semibold tracking-tight text-brand-navy">Services</h2>
    <p class="mt-2 max-w-2xl text-sm leading-relaxed text-brand-navy/70 md:text-base">
      Un accompagnement simple : on clarifie votre positionnement, puis on produit du contenu régulier qui vous ressemble.
    </p>
    <div class="mt-6 grid gap-4 md:grid-cols-3">
      {[
        {
          title: "Ghostwriting LinkedIn",
          bullets: ["Posts hebdomadaires", "Écrits dans votre voix", "Validation avant publication"],
        },
        {
          title: "Optimisation de profil",
          bullets: ["Headline + À propos", "Preuves & structure", "Alignement mots-clés (FR)"],
        },
        {
          title: "Stratégie de contenu",
          bullets: ["Piliers + angles", "Calendrier simple", "Système réutilisable"],
        },
      ].map((s) => (
        <div class="rounded-3xl border border-brand-navy/10 bg-white/50 p-6">
          <div class="text-base font-semibold text-brand-navy">{s.title}</div>
          <ul class="mt-3 space-y-2 text-sm text-brand-navy/80">
            {s.bullets.map((b) => (
              <li class="flex gap-2">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-orange" />
                <span>{b}</span>
              </li>
            ))}
          </ul>
          <a class="mt-5 inline-flex text-sm font-semibold text-brand-navy hover:underline" href="/services">
            Voir le détail →
          </a>
        </div>
      ))}
    </div>
  </section>

  <section class="mt-16">
    <CTA />
  </section>
</BaseLayout>

